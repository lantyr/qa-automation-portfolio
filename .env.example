# Copy to .env and fill in for local runs. .env is gitignored.

# === Demo targets (override only if you need a fork) ===
SAUCE_BASE_URL=https://www.saucedemo.com
REQRES_BASE_URL=https://reqres.in/api

# === SauceDemo test users (public credentials documented at saucedemo.com) ===
SAUCE_USER_STANDARD=standard_user
SAUCE_USER_LOCKED=locked_out_user
SAUCE_USER_PROBLEM=problem_user
SAUCE_PASSWORD=secret_sauce

# === ReqRes test API key (public demo, leave default) ===
REQRES_API_KEY=reqres-free-v1

# === Browser ===
# headless | headed
BROWSER_MODE=headless
